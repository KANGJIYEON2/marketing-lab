# ============================================================
# marketing-lab — Environment Variables Template
# ============================================================
# Copy to .env (gitignored) and fill values.
# Inject into n8n via your hosting platform (Railway Variables /
# Docker --env-file / n8n Cloud env settings).
# ============================================================

# ---- Notion DB IDs (32-char hex from DB URL) ----
NOTION_DB_CONTENT_IDEAS=
NOTION_DB_CONTENT_DRAFTS=
NOTION_DB_LEADS=
NOTION_DB_CAMPAIGN_METRICS=
NOTION_DB_INBOX=
NOTION_DB_COMPETITOR_TIMELINE=

# ---- Slack channel names (include #) ----
SLACK_CHANNEL_LOG=#automation-log
SLACK_CHANNEL_IDEAS=#content-ideas
SLACK_CHANNEL_INBOX=#inbox
SLACK_CHANNEL_COMPETITOR=#competitor-intel
SLACK_CHANNEL_REPORT=#weekly-report

# ---- API Keys (also stored in n8n Credentials; .env is for code/scripts only) ----
# Anthropic — required
ANTHROPIC_API_KEY=

# OpenAI — optional (Whisper, fallback LLM)
OPENAI_API_KEY=

# ---- Automation-specific (filled per automation as needed) ----

# 01 Idea Engine
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
X_BEARER_TOKEN=

# 02 YouTube Factory
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=
SUPADATA_API_KEY=

# 03 Unified Inbox
META_PAGE_ID=
META_IG_USER_ID=
META_GRAPH_ACCESS_TOKEN=
GMAIL_LABEL=inbox-monitor

# 04 Competitor Intel
COMPETITOR_DOMAINS=competitor-a.com,competitor-b.com,competitor-c.com

# 05 SEO Hunter
GSC_SERVICE_ACCOUNT_JSON_PATH=
GSC_SITE_URL=https://yourdomain.com/

# 06 Ad Evolution
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=
GOOGLE_ADS_CUSTOMER_ID=

# 07 Lead Sequence
APOLLO_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@yourdomain.com
RESEND_FROM_NAME=Your Name
LEAD_HOT_SCORE_THRESHOLD=70

# 09 Weekly Report
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_JSON_PATH=
